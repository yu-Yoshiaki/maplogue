{
  "name": "maplogue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "REALTIME_DRAW_ALLOW_REMOTE_WRITE=1 vite --host 0.0.0.0 --port 5174",
